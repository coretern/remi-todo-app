{
  "expo": {
    "name": "Remi Todo",
    "slug": "remi-todo",
    "version": "1.0.2",
    "description": "Remi Todo is a premium task manager designed for elegance and productivity. Features local privacy and a beautiful dashboard to help you conquer your missions every day.",
    "orientation": "portrait",
    "icon": "./assets/images/remiicon.png",
    "splash": {
      "image": "./assets/images/remiicon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F9FA"
    },
    "scheme": "com.remi.todoapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.remi.todoapp",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.remi.todoapp",
      "versionCode": 2,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/remiicon.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/remiicon.png"
      },
      "permissions": [
        "NOTIFICATIONS",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "VIBRATE",
        "WAKE_LOCK"
      ],
      "intentFilters": [
        {
          "action": "android.intent.action.VIEW",
          "data": {
            "scheme": "remi-todo"
          }
        }
      ],
      "notification": {
        "icon": "./assets/images/android-icon-monochrome.png",
        "color": "#006EAF"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/remiicon.png",
      "description": "Remi Todo - Premium Minimalist Task Manager"
    },
    "plugins": [
      "@notifee/react-native",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/remiicon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F8F9FA",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableMinifyInReleaseBuilds": true
          }
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "TodoWidget",
              "label": "Remi Todo Tasks",
              "description": "Check your active missions at a glance",
              "src": "./widget/index.js",
              "targetId": "todo_widget",
              "previewImage": "./assets/images/remiicon.png",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "updatePeriodMillis": 3600000
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a4152f35-6802-4348-856f-0392b441031e"
      }
    }
  }
}
